// Схема БД AI Channel Manager.
// Спроектирована СРАЗУ под мультиканальность и любую нишу: вся тематика
// (слова-триггеры, контент, тексты, настройки) живёт в данных канала, не в коде.
// Новый канал = новые строки в таблицах, код не меняется.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7: строка подключения живёт в prisma.config.ts (для CLI/Migrate),
// а рантайм-клиент получает её через драйвер-адаптер @prisma/adapter-pg.
datasource db {
  provider = "postgresql"
}

// Тип интерактива поста (из content.json канала №1).
enum InteractiveType {
  keyword_trigger
  button_choice
  button_prediction
  vote_123
}

// Слот публикации в течение дня.
enum Slot {
  morning
  evening
}

// День недели поста контент-плана.
enum Weekday {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

// Источник поста (Шаг 13b) — якорь голоса против нейрослопа: примеры стиля
// (`getSamplePosts`) в приоритете берут человеческие посты, чтобы AI не учился
// у вчерашнего себя. Сид-контент канала — `human` (написан людьми).
enum PostOrigin {
  human
  ai
}

// Статус эксперимента (Шаг 13b). Одно измерение за раз: активен ровно один
// эксперимент на канал (инвариант держит репозиторий, не БД).
enum ExperimentStatus {
  active
  stopped
}

// Тариф владельца (Шаг 14e). `trial` — бесплатный доступ до `trialUntil`, после
// которого гейт закрывается сам; `active` — бессрочно (супервладелец, платящий).
// ⚠️ Дефолт `active` НАМЕРЕННО: миграция не должна запереть тех, кто уже пользуется
// ботом (в т.ч. супервладельца). Триал ставится явно — приглашением.
enum OwnerPlan {
  trial
  active
}

// Владелец каналов (Шаг 14a) — арендатор SaaS. Фундамент мультитенанта: до 14a бот
// одно-арендный (единственный ADMIN_ID), и каналы никому не «принадлежали».
// Супервладелец (= ADMIN_ID) заводится идемпотентно при старте (`ensureOwner`).
// Разграничение доступа по владельцу включено в 14b, срок доступа — в 14e.
model Owner {
  id             String    @id @default(cuid())
  telegramUserId String    @unique // числовой Telegram user id (строкой — как chatId)
  name           String? // отображаемое имя для экрана «Владельцы» (14b)
  plan           OwnerPlan @default(active) // тариф (14e)
  trialUntil     DateTime? // конец бесплатного доступа; null при plan=active (14e)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  channels   Channel[]
  botAccount BotAccount?
}

// Свой бот-токен владельца (Шаг 14b-bis-1) — «лицо» клиента: его канал ведёт ЕГО
// бот, а не общий @MasterPost. Отдельная модель, а не поле на `Owner`, потому что у
// токена своя жизнь: имя бота, работоспособность, последняя ошибка, дата подключения.
//
// ⚠️ ТОКЕН = ПОЛНЫЙ КОНТРОЛЬ над каналами клиента, поэтому в БД он лежит ТОЛЬКО
// зашифрованным (`tokenCipher`, AES-256-GCM, ключ в env `BOT_TOKEN_ENC_KEY`) —
// утёкший дамп базы не даёт доступа к чужим каналам.
//
// `@unique` на `ownerId` — один бот на владельца (мультибот на одного клиента не
// нужен и усложнил бы маршрутизацию). `@unique` на `botUserId` — один и тот же бот
// нельзя подключить двум владельцам: два long polling на один токен дают 409.
//
// ⚠️ В 14b-bis-1 токен ТОЛЬКО хранится и проверяется (`getMe`): процесс по-прежнему
// поднимает один бот из env. Запуск ботов клиентов — 14b-bis-2, маршрутизация
// публикации — 14b-bis-3.
model BotAccount {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  owner       Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  botUserId   String   @unique // числовой id бота из getMe (строкой — как chatId)
  username    String // @username бота: единственное, что показываем владельцу
  tokenCipher String // зашифрованный токен (формат `v1:iv:tag:ciphertext`)
  isActive    Boolean  @default(true) // выключён владельцем — не поднимать (14b-bis-2)
  lastError   String? // последняя ошибка запуска/getMe — чтобы молчащий бот был объясним
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Канал — корень всех данных. Хранит тематику и настройки, не код.
model Channel {
  id            String    @id @default(cuid())
  title         String
  username      String?   @unique // @sofia_gada1ka и т.п.
  chatId        String? // цель публикации автопостинга: @username или числовой -100… (Шаг 4)
  niche         String // эзотерика / новости / бизнес — любая ниша
  language      String    @default("ru")
  region        String?
  goal          String?
  toneOfVoice   String?
  timezone      String    @default("Europe/Moscow")
  campaignStart DateTime? // старт контент-плана (для расчёта недели/дня)
  triggerWords  String[]  @default([]) // слова-триггеры в комментах, напр. ["карта","кофе","руна"]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Владелец канала (Шаг 14a). NULLABLE намеренно: существующие каналы бэкофиллятся
  // на супервладельца при старте (`claimOrphanChannels`), а `createChannel`/онбординг
  // начнут штамповать владельца только в 14b. Пока по `ownerId` НИЧЕГО не фильтруется,
  // поэтому канал без владельца ведёт себя ровно как раньше. `SetNull` при удалении
  // владельца — не роняем его контент (каналы вернутся супервладельцу на следующем старте).
  ownerId String?
  owner   Owner?  @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  posts        Post[]
  textPools    TextPool[]
  settings     Setting[]
  cooldowns    Cooldown[]
  subscribers  Subscriber[]
  pendingPosts PendingPost[]
  postMetrics  PostMetric[]
  statSnapshots ChannelStatSnapshot[]
  experiments  Experiment[]

  @@index([ownerId])
}

// Пост контент-плана. Поля повторяют content.json.
model Post {
  id              String          @id @default(cuid())
  channelId       String
  channel         Channel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  externalId      Int // исходный id из content.json (1..32) — ключ для идемпотентного сида
  week            Int
  day             Weekday
  slot            Slot
  time            String // "10:00"
  title           String
  text            String
  cta             String
  interactiveType InteractiveType
  keyword         String? // для keyword_trigger
  reactions       String[]        @default([])
  choices         Json? // для button_choice: [{label, answer}]
  button          Json? // для button_prediction: {type, label}
  pexelsQuery     String?
  photoPath       String?
  // Шаг 6c — разовый пост вне недельного плана (публикуется один раз в publishAt).
  // oneOff=true → строка не участвует в недельной выдаче (фильтр oneOff:false);
  // week/day/slot у такой строки — плейсхолдеры. photoFileId — своё загруженное фото
  // (Telegram file_id, имеет высший приоритет источника фото).
  oneOff          Boolean         @default(false)
  publishAt       DateTime? // когда опубликовать (только oneOff)
  publishedAt     DateTime? // когда опубликован (дедуп между тиками планировщика)
  photoFileId     String?
  // Шаг 13b — источник поста (якорь голоса). Посты контент-плана написаны людьми → human.
  origin          PostOrigin      @default(human)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([channelId, externalId])
  @@index([channelId, week, day, slot])
  @@index([oneOff, publishedAt, publishAt])
}

// Пул текстов-предсказаний (замена DEFAULT_TEXTS / texts.json).
model TextPool {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  key       String // karta | kofe | runa | button_love | button_money | button_cards
  texts     String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, key])
  @@index([channelId])
}

// Произвольные настройки канала (замена settings.json).
model Setting {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@unique([channelId, key])
  @@index([channelId])
}

// Кулдаун на триггер для пользователя (Шаг 2).
model Cooldown {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String // telegram user id
  trigger   String
  expiresAt DateTime
  recent    String[] @default([]) // ключи недавно показанных ответов (анти-повтор «колода»)
  createdAt DateTime @default(now())

  @@unique([channelId, userId, trigger])
  @@index([channelId, expiresAt])
}

// Пост, ожидающий одобрения админом перед публикацией (Шаг 5).
// Снимок текстовых полей: правки на одобрении меняют ЭТУ копию, не трогая
// контент-план (как `post = dict(post)` в Python-боте).
model PendingPost {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  externalId Int? // исходный пост контент-плана (для трассировки); null — иной источник
  title      String
  text       String
  cta        String
  photoUrl   String? // кэш выбранного фото (URL Pexels или Telegram file_id) — Шаг 6a
  pexelsQuery String? // запрос подбора фото — Шаг 10b: чтобы «🔄 Другое фото» работало и у AI-постов (externalId=null)
  // Шаг 13b — вариант активного эксперимента, назначенный AI-посту при постановке
  // в очередь (ключ из каталога 13a); null — пост вне эксперимента.
  variantKey String?
  createdAt  DateTime @default(now())

  @@index([channelId, createdAt])
}

// Снимок метрик поста канала, снятый через личный аккаунт (MTProto, Шаг 7c).
// Токен бота просмотры постов не видит — их читает только личный аккаунт (GramJS).
// Upsert по [channelId, messageId]: повторный прогон обновляет метрики, не плодит дубли.
model PostMetric {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messageId   Int // id сообщения в канале (из MTProto)
  views       Int      @default(0)
  reactions   Int      @default(0)
  replies     Int      @default(0)
  preview     String // короткий текст поста (для отчёта/истории)
  // Контентные измерения поста (Шаг 12b) — которых нет в сыром снимке 7c.
  // Питают ядро 12a: «что заходит» = медиа/кнопки/длина против вовлечённости.
  hasMedia    Boolean  @default(false) // есть ли фото/видео/док (msg.media)
  hasButtons  Boolean  @default(false) // есть ли inline-кнопки (msg.replyMarkup)
  charLen     Int      @default(0) // длина текста/подписи поста (символов)
  // Шаг 13b — источник и вариант эксперимента опубликованного поста. `origin`
  // питает якорь голоса; `variantKey` группирует посты по вариантам при вердикте
  // эксперимента (13d). null variantKey — пост вне эксперимента.
  origin      PostOrigin @default(human)
  variantKey  String?
  postedAt    DateTime // дата публикации сообщения
  collectedAt DateTime @updatedAt // когда последний раз сняли метрики

  @@unique([channelId, messageId])
  @@index([channelId, postedAt])
}

// Периодический снимок агрегатов канала (Шаг 12b) — лёгкая таблица для тренда охвата.
// Джоб аналитики раз в сутки кладёт сюда «сколько подписчиков / сколько постов за 7д /
// средние просмотры и ERR за 7д». Ядро 12a сравнивает снимки во времени (растёт охват
// или падает), не пересчитывая всё по сырым метрикам. Один канал → много снимков.
model ChannelStatSnapshot {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  capturedAt  DateTime @default(now()) // момент снимка
  subscribers Int? // число подписчиков (из нативной статы; null — не удалось получить)
  postCount7d Int      @default(0) // постов за последние 7 дней
  avgViews7d  Int      @default(0) // средние просмотры за 7 дней
  avgErr7d    Float    @default(0) // средний ERR за 7 дней (доля 0..1)
  // Шаг 12b-2: нативные «лучшие часы» Telegram (stats.getBroadcastStats → topHoursGraph),
  // ранжированный TopHour[] (best-first). null/пусто — стата недоступна (мягкая деградация).
  topHours    Json? // TopHour[] { hour: 0..23, value }

  @@index([channelId, capturedAt])
}

// Эксперимент над контентом (Шаг 13b) — последовательный A/B в Telegram-канале.
// Настоящего A/B нет (нельзя показать половине подписчиков вариант А), поэтому
// варианты ОДНОГО измерения (стиль CTA / фото / длина / заголовок из каталога 13a)
// чередуются между постами. `assignedCount` — счётчик уже назначенных вариантов:
// детерминированная ротация (`assignVariant`) держит выборки честными. Инвариант
// «один активный эксперимент на канал» держит репозиторий (не БД).
model Experiment {
  id            String           @id @default(cuid())
  channelId     String
  channel       Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dimension     String // ключ измерения из каталога 13a (cta_style | media | length | headline_style)
  status        ExperimentStatus @default(active)
  assignedCount Int              @default(0) // сколько постов уже получили вариант (ротация)
  startedAt     DateTime         @default(now())
  stoppedAt     DateTime? // когда остановлен (null — идёт)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([channelId, status])
}

// Подписчик канала (заготовка под аналитику).
model Subscriber {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String // telegram user id
  username  String?
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  meta      Json?

  @@unique([channelId, userId])
  @@index([channelId])
}
