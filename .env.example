# Скопируй этот файл в .env и подставь реальные значения.
# .env в .gitignore — секреты НЕ попадают в git.

# Токен Telegram-бота из @BotFather
BOT_TOKEN=

# Порт HTTP health-сервера (Koyeb задаёт PORT сам; локально по умолчанию 8000)
PORT=8000

# Уровень логов pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Строка подключения к PostgreSQL.
# Локально: postgresql://postgres:ПАРОЛЬ@localhost:5432/aicm_dev?schema=public
# Прод (Neon/Supabase): полная строка из панели провайдера.
DATABASE_URL=

# Telegram user id администратора — кому доступно меню управления (/menu).
# Узнать свой id: напиши боту @userinfobot.
ADMIN_ID=

# Ключ Pexels для подбора фото к постам (Шаг 6a, бесплатная версия).
# Получить бесплатно: https://www.pexels.com/api/ . Можно оставить пустым —
# тогда посты публикуются без фото (мягкая деградация).
PEXELS_API_KEY=

# MTProto/GramJS для аналитики просмотров (Шаг 7b). Все три ОПЦИОНАЛЬНЫ: без них
# отчёт по просмотрам отключён, бот работает как раньше.
# api_id/api_hash: https://my.telegram.org → API development tools.
# TELEGRAM_SESSION: получить командой `npm run gen-session` (одноразовый вход с телефона).
# ⚠️ TELEGRAM_SESSION = ПОЛНЫЙ доступ к личному аккаунту. НИКОГДА не коммить в git —
#    только локальный .env (в .gitignore) или переменные хостинга (Railway).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Ключ шифрования bot-токенов клиентов (Шаг 14b-bis-1). Опционален: без него
# экран «🤖 Мой бот» не даёт подключить своего бота, остальное работает как раньше.
# Любая длинная фраза от 16 символов (она прогоняется через SHA-256).
# ⚠️ Потеря ключа = сохранённые токены не расшифровать, клиенты вводят их заново.
#    Только в env (Railway), НИКОГДА не в git.
BOT_TOKEN_ENC_KEY=
