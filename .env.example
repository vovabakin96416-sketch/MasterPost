# Скопируй этот файл в .env и подставь реальные значения.
# .env в .gitignore — секреты НЕ попадают в git.

# Токен Telegram-бота из @BotFather
BOT_TOKEN=

# Порт HTTP health-сервера (Koyeb задаёт PORT сам; локально по умолчанию 8000)
PORT=8000

# Уровень логов pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Строка подключения к PostgreSQL.
# Локально: postgresql://postgres:ПАРОЛЬ@localhost:5432/aicm_dev?schema=public
# Прод (Neon/Supabase): полная строка из панели провайдера.
DATABASE_URL=
